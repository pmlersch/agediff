###############################################################################
## get_ess.R
##
## Extract and harmonize European Social Survey (ESS) data.
##
## Harmonized output variables:
##   year          : survey / interview year
##   sex           : respondent sex  (1 = male, 2 = female)
##   sex_partner   : partner's sex   (1 = male, 2 = female)
##   birth_cohort  : respondent's year of birth
##   marital_status: factor – "married", "civil_partnership", "separated",
##                             "divorced", "widowed", "never_married"
##   age           : respondent age in years
##   age_partner   : partner / spouse age in years
##   country_iso   : ISO 3166-1 alpha-2 code
##   country_name  : human-readable country name
##   weight        : combined design × post-stratification weight
##   source        : "ess"
##
## Input  : data/ess/ess.dta
## Output : data/harmonized/ess_harmonized.rds
###############################################################################
# Load the data.table package, which provides fast data manipulation tools
library(data.table)
# Load the haven package, which can read Stata (.dta), SPSS, and SAS files
library(haven)
# Load the countrycode package, which converts between country code formats
library(countrycode)
# Run another R script that defines helper functions for quality-checking output
source(file.path("code", "check_harmonized.R"))
###############################################################################
## harmonize_demographic_variables.R
##
## Harmonize demographic variables across three international survey sources:
##   1. IPUMS International  (census / register microdata)
##   2. ISSP                 (International Social Survey Programme)
##   3. ESS                  (European Social Survey)
###############################################################################
################################################################################
# Libraries
library(data.table)
library(dplyr)
library(countrycode)   # for standardizing country identifiers
################################################################################
# File paths (adjust to your local folders)
WD <- "D:/Papers/2025_agediff/code"
setwd(WD)
################################################################################
# Get data and harmonize
source("code/get_ess.R")
WD <- "D:/Papers/2025_agediff/"
setwd(WD)
################################################################################
# Get data and harmonize
source("code/get_ess.R")
source("code/merge_data.R")
View(out)
# Load the data.table package, which provides fast data manipulation tools
library(data.table)
# Load the haven package, which can read Stata (.dta), SPSS, and SAS files
library(haven)
###############################################################################
## get_ess.R
##
## Extract and harmonize European Social Survey (ESS) data.
##
## Harmonized output variables:
##   year          : survey / interview year
##   sex           : respondent sex  (1 = male, 2 = female)
##   sex_partner   : partner's sex   (1 = male, 2 = female)
##   birth_cohort  : respondent's year of birth
##   marital_status: factor – "married", "civil_partnership", "separated",
##                             "divorced", "widowed", "never_married"
##   age           : respondent age in years
##   age_partner   : partner / spouse age in years
##   country_iso   : ISO 3166-1 alpha-2 code
##   country_name  : human-readable country name
##   weight        : combined design × post-stratification weight
##   source        : "ess"
##
## Input  : data/ess/ess.dta
## Output : data/harmonized/ess_harmonized.rds
###############################################################################
# Load the data.table package, which provides fast data manipulation tools
library(data.table)
# Load the haven package, which can read Stata (.dta), SPSS, and SAS files
library(haven)
# Load the countrycode package, which converts between country code formats
library(countrycode)
# Run another R script that defines helper functions for quality-checking output
source(file.path("code", "check_harmonized.R"))
# ---- File paths --------------------------------------------------------------
# Build the path to the raw ESS Stata file using file.path() so it works on
# both Windows (backslash) and Mac/Linux (forward slash)
path_ess    <- file.path("data", "ess", "ess.dta")
# Build the path where the cleaned output file will be saved (.rds is R's
# native binary format — fast to save/load and preserves column types)
path_out    <- file.path("data", "harmonized", "ess_harmonized.rds")
# =============================================================================
# Read & harmonize
# =============================================================================
# Print a progress message to the console so you know the script is running
message("[ESS] Reading ", path_ess)
# Read the Stata .dta file with read_dta(), then convert it to a data.table
# (data.table is like a data.frame but much faster for large datasets)
raw <- as.data.table(read_dta(path_ess))
# Convert all column names to lowercase so references like raw$gndr always work
# regardless of how the original file stored them (e.g. GNDR, Gndr, gndr)
names(raw) <- tolower(names(raw))
# --- age -------------------------------------------------------------------
# ESS uses 999 as a sentinel / "not applicable" code for age (agea column).
# Replace any value >= 999 with NA (R's missing-value marker) so it doesn't
# skew calculations. The := operator updates the column in-place (no copy).
raw[agea >= 999, agea := NA_integer_]
# Create a new column called 'age' by converting agea to a plain integer.
# (read_dta sometimes imports numbers with extra Stata metadata; as.integer
# strips that metadata and gives us a clean number.)
raw[, age := as.integer(agea)]
# --- sex -------------------------------------------------------------------
# Create a 'sex' column by translating the ESS gender code (gndr) into our
# harmonized coding: 1 = male, 2 = female, anything else = NA.
# fcase() is data.table's fast vectorised case-when — it evaluates conditions
# top to bottom and returns the matching value for each row.
# The 'L' suffix (e.g. 1L) tells R these are integers, not floating-point
# numbers — this is slightly more memory-efficient and avoids type mismatches.
raw[, sex := fcase(
gndr == 1L, 1L,   # ESS code 1 → male
gndr == 2L, 2L,   # ESS code 2 → female
default = NA_integer_  # any other value (refused, don't know, etc.) → NA
)]
# --- year ------------------------------------------------------------------
# Priority order for determining survey year (highest to lowest):
#   1. inwds     — interview-start datetime (yyyy-mm-dd hh:mm:ss); most precise
#   2. questcmp  — questionnaire-completion datetime
#   3. scwsds    — screen / web-start datetime
#   4. inwyys    — integer interview-start year (rounds 3+)
#   5. inwyr     — integer interview year (rounds 1–2)
#   6. essround  — round-to-year mapping (last resort)
# inwds: extract the 4-digit year from the leading "yyyy" of the datetime
# string. substr() is vectorised and returns NA when inwds is already NA,
# so no special NA handling is needed here.
if ("inwds" %in% names(raw)) {
raw[, inwds_year := as.integer(substr(as.character(inwds), 1L, 4L))]
} else {
raw[, inwds_year := NA_integer_]
}
# questcmp: questionnaire-completion datetime — same extraction approach as inwds.
if ("questcmp" %in% names(raw)) {
raw[, questcmp_year := as.integer(substr(as.character(questcmp), 1L, 4L))]
} else {
raw[, questcmp_year := NA_integer_]
}
# scwsds: screen / web-start datetime — same extraction approach as inwds.
if ("scwsds" %in% names(raw)) {
raw[, scwsds_year := as.integer(substr(as.character(scwsds), 1L, 4L))]
} else {
raw[, scwsds_year := NA_integer_]
}
# intersect() returns only the column names that actually exist in the dataset,
# so this loop safely handles datasets that have one, both, or neither variable.
for (.v in intersect(c("inwyys", "inwyr"), names(raw))) {
# ESS uses three numeric sentinel codes for missing interview year:
#   7777 = Refusal, 8888 = Don't know, 9999 = No answer / Not applicable
# haven::read_dta() additionally imports Stata extended missing values
# (.a, .b, …) directly as NA, so those are already handled before this step.
# get(.v) looks up the column whose name is stored in the variable .v;
# (.v) on the left-hand side of := updates that same column in-place.
raw[get(.v) >= 7777, (.v) := NA_integer_]
}
# Build a vector of year-source columns that are actually present, in priority
# order, then fcoalesce() picks the first non-NA value for each row.
year_sources <- intersect(
c("inwds_year", "questcmp_year", "scwsds_year", "inwyys", "inwyr"),
names(raw)
)
if (length(year_sources) > 0L) {
raw[, year := do.call(fcoalesce, lapply(year_sources, function(v) as.integer(get(v))))]
} else {
raw[, year := NA_integer_]
}
# Drop the temporary extraction columns
raw[, inwds_year    := NULL]
raw[, questcmp_year := NULL]
raw[, scwsds_year   := NULL]
# Last-resort fallback: essround is always present and never missing.
# Map round numbers to the calendar year fieldwork started (ESS documentation).
# This only fills rows where both inwyys and inwyr were absent or missing;
# it is intentionally conservative and does NOT overwrite valid interview years.
if ("essround" %in% names(raw)) {
round_to_year <- c(
"1" = 2002L, "2" = 2004L, "3" = 2006L, "4" = 2008L, "5" = 2010L,
"6" = 2012L, "7" = 2014L, "8" = 2016L, "9" = 2018L, "10" = 2020L,
"11" = 2022L
)
# as.character() converts the numeric round to the name used in round_to_year.
# The result is coerced back to integer via as.integer() for type consistency.
raw[is.na(year) & !is.na(essround),
year := as.integer(round_to_year[as.character(as.integer(essround))])]
}
# --- birth cohort ----------------------------------------------------------
# ESS uses 7777+ as sentinel codes (e.g. 7777 = "not applicable",
# 8888 = "don't know", 9999 = "refused") for year of birth (yrbrn).
# Replace them all with NA so they aren't treated as real birth years.
raw[yrbrn >= 7777, yrbrn := NA_integer_]
# Copy the cleaned birth year into a new, clearly named column
raw[, birth_cohort := as.integer(yrbrn)]
# For rows where birth_cohort is still missing but we know both the
# respondent's age and the interview year, we can back-calculate:
#   birth year ≈ interview year − age
# This only runs on rows where birth_cohort IS NA and age/year are NOT NA.
raw[is.na(birth_cohort) & !is.na(age) & !is.na(year),
birth_cohort := year - age]
# --- marital status --------------------------------------------------------
# ESS has two versions of the marital-status question across its rounds:
#   maritalb (rounds with civil-partnership option, 6 categories)
#   maritala (older rounds, 5 categories — no civil_partnership)
# We prefer maritalb; fall back to maritala if maritalb is absent.
if ("maritalb" %in% names(raw)) {
# maritalb is the more complete variable — map its numeric codes to labels
raw[, marital_status := fcase(
maritalb == 1L, "married",
maritalb == 2L, "civil_partnership",  # only in maritalb
maritalb == 3L, "separated",
maritalb == 4L, "divorced",
maritalb == 5L, "widowed",
maritalb == 6L, "never_married",
default = NA_character_  # refused / don't know / missing
)]
} else if ("maritala" %in% names(raw)) {
# maritala is the fallback variable (no civil_partnership category)
raw[, marital_status := fcase(
maritala == 1L, "married",
maritala == 3L, "separated",
maritala == 4L, "divorced",
maritala == 5L, "widowed",
maritala == 6L, "never_married",
default = NA_character_
)]
}
# If the dataset has both columns (e.g. a combined multi-round file),
# use maritala to fill in any rows that maritalb left as NA.
# This handles cases where one round collected maritalb and another collected
# maritala, so neither variable alone covers all rows.
if (all(c("maritalb", "maritala") %in% names(raw))) {
raw[is.na(marital_status), marital_status := fcase(
maritala == 1L, "married",
maritala == 3L, "separated",
maritala == 4L, "divorced",
maritala == 5L, "widowed",
maritala == 6L, "never_married",
default = NA_character_
)]
}
# --- partner's age & sex (household grid) ----------------------------------
# ESS collects a household grid listing up to 5 other household members
# (persons 2–6). For each person it records:
#   rshipa{i} — relationship to respondent (1 = husband/wife/partner)
#   yrbrna{i} — year of birth
#   gndr{i}   — gender
# The variable prefix changed between rounds:
#   ESS Round 1 only : rship2–rship6   (no trailing 'a')
#   ESS Rounds 2–10+ : rshipa2–rshipa6 (with trailing 'a')
# Detect which prefix is present so the code works across all rounds.
rshp_prefix <- if (paste0("rshipa", 2) %in% names(raw)) {
"rshipa"   # modern prefix (rounds 2+)
} else if (paste0("rship", 2) %in% names(raw)) {
"rship"    # legacy prefix (round 1)
} else {
NULL       # household grid absent entirely
}
# Build character vectors of the column names we'll need to look up
rshp_cols <- if (!is.null(rshp_prefix)) paste0(rshp_prefix, 2:6) else character(0)
# paste0() glues strings together with no separator; 2:6 expands to 2,3,4,5,6
yob_cols  <- paste0("yrbrna", 2:6)   # year-of-birth columns for persons 2–6
gndr_cols <- paste0("gndr",   2:6)   # gender columns for persons 2–6
# Check that the household grid columns we need actually exist in the data
has_hh_grid <- !is.null(rshp_prefix) &&
all(c(rshp_cols[1], yob_cols[1]) %in% names(raw))
# && is the logical AND operator; both conditions must be TRUE
if (has_hh_grid) {
# Inform the user which prefix was found
message("[ESS] Household grid detected (prefix: '", rshp_prefix,
"') — deriving partner age and sex.")
# Initialise partner columns as all-NA; we'll fill them in the loop below
raw[, partner_yob  := NA_integer_]  # partner's year of birth (temporary)
raw[, sex_partner  := NA_integer_]  # partner's gender (1=male, 2=female)
# Loop over household members 2 through 6
for (i in 2:6) {
# Build the actual column names for this household member number
rshp_var <- paste0(rshp_prefix, i)  # e.g. "rshipa2", "rshipa3", …
yob_var  <- paste0("yrbrna", i)     # e.g. "yrbrna2", "yrbrna3", …
gndr_var <- paste0("gndr",   i)     # e.g. "gndr2",   "gndr3",   …
# Skip this household member if either required column is missing
if (!all(c(rshp_var, yob_var) %in% names(raw))) next
# For rows where:
#   • we haven't found a partner yet (partner_yob is still NA)
#   • this household member's relationship code is not NA
#   • this household member IS the respondent's partner (code == 1)
#   • the birth year is not NA and is a real year (< 7777)
# … record their birth year as the partner's birth year.
# get() retrieves the column whose name is stored in the string variable.
raw[is.na(partner_yob) &
!is.na(get(rshp_var)) & get(rshp_var) == 1L &
!is.na(get(yob_var))  & get(yob_var) < 7777,
partner_yob := as.integer(get(yob_var))]
# Do the same for the partner's gender if the gender column exists
if (gndr_var %in% names(raw)) {
raw[is.na(sex_partner) &
!is.na(get(rshp_var)) & get(rshp_var) == 1L &
!is.na(get(gndr_var)) & get(gndr_var) %in% c(1L, 2L),
sex_partner := as.integer(get(gndr_var))]
}
}
# Calculate partner's current age: interview year minus their birth year
raw[, age_partner := year - partner_yob]
# Implausible ages (under 15 or over 110) are almost certainly data errors;
# set them to NA rather than letting them distort the analysis
raw[age_partner < 15 | age_partner > 110, age_partner := NA_integer_]
} else {
# No household grid in this file — we cannot derive partner information
message("[ESS] No household grid found — partner age and sex set to NA.")
raw[, age_partner := NA_integer_]  # fill column with NA for all rows
raw[, sex_partner := NA_integer_]  # fill column with NA for all rows
}
# --- country ---------------------------------------------------------------
# cntry holds the 2-letter country code (e.g. "DE", "FR").
# as.character() converts it from a Stata labelled type to a plain string.
# trimws() removes any leading/trailing whitespace.
# toupper() ensures the code is always uppercase (e.g. "de" → "DE").
raw[, country_iso  := toupper(trimws(as.character(cntry)))]
# countrycode() translates ISO 2-letter codes into full English country names.
# origin = "iso2c"            → input format is 2-letter ISO code
# destination = "country.name" → output should be the English country name
# warn = FALSE                → suppress warnings for unmatched codes
raw[, country_name := countrycode(
country_iso, origin = "iso2c", destination = "country.name", warn = FALSE
)]
# --- weight ----------------------------------------------------------------
# ESS provides two weights that should be multiplied together for correct
# population-level estimates:
#   dweight  — design weight (corrects for different sampling probabilities)
#   pspwght  — post-stratification weight (corrects for non-response bias)
if (all(c("dweight", "pspwght") %in% names(raw))) {
# Both weights are present — combine them as the ESS documentation recommends
raw[, weight := dweight * pspwght]
} else if ("dweight" %in% names(raw)) {
# Only the design weight is available — use it on its own
raw[, weight := dweight]
} else {
# No weights at all — assign 1 so every respondent counts equally
raw[, weight := 1]
}
# --- assemble output -------------------------------------------------------
# Select only the harmonized columns we want to keep.
# .() inside data.table's [] is shorthand for list() and selects columns.
# source = "ess" adds a literal string column so we can identify where each
# row came from when later merging with other survey datasets.
out <- raw[, .(
year, sex, sex_partner, birth_cohort, marital_status,
age, age_partner,
country_iso, country_name, weight,
source = "ess"
)]
# Convert marital_status from a plain character column to a factor.
# A factor is R's way of representing a categorical variable with a fixed
# set of allowed values (levels). Specifying levels= sets both the allowed
# values and their display order (useful for tables and plots).
out[, marital_status := factor(
marital_status,
levels = c("married", "civil_partnership", "separated",
"divorced", "widowed", "never_married")
)]
# Keep only respondents with a identified partner.
# age_partner is NA when no household-grid member was coded as a spouse/partner,
# so filtering on it effectively drops all partner-less observations.
out <- out[!is.na(age_partner)]
# Print a summary message; format() adds a comma as the thousands separator
message("[ESS] Harmonized ", format(nrow(out), big.mark = ","), " records.")
# Run the project's standard quality checks (defined in check_harmonized.R)
run_data_quality_checks(out, "ess")
# Let the user know where the output file will be saved
message("[ESS] Saving to ", path_out)
# Save the cleaned data as an .rds file (R's compact binary format).
# Use readRDS(path_out) later to reload it without re-running this script.
saveRDS(out, path_out)
# Final confirmation message
message("[ESS] Done.")
View(raw)
